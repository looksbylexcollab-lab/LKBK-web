# Supabase — get from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — server-only, used for waitlist API route
# Get from Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Skimlinks — add after you're approved (your numeric publisher ID)
# NEXT_PUBLIC_SKIMLINKS_PUB_ID=123456
